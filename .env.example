# ─── Auth session ────────────────────────────────────────────────────────────
# 32-byte random base64 string. Generate: openssl rand -base64 32
SESSION_SECRET=

# Base URL of the deployed app, no trailing slash
APP_URL=http://localhost:3000

# ─── Anthropic (Claude API) ──────────────────────────────────────────────────
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-opus-4-7 for reasoning, claude-haiku-4-5 for summaries
ANTHROPIC_MODEL_REASONING=claude-opus-4-7
ANTHROPIC_MODEL_FAST=claude-haiku-4-5

# ─── Gmail OAuth ─────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth client (Web)
# Authorized redirect URI: ${APP_URL}/api/auth/callback/gmail
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Microsoft (Office 365 / Outlook) OAuth ──────────────────────────────────
# Azure Portal → App registrations → New registration (single-tenant or common)
# Redirect URI (Web): ${APP_URL}/api/auth/callback/microsoft
# API permissions: Mail.ReadWrite, Mail.Send, offline_access, User.Read, openid, profile, email
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# ─── IMAP (Yahoo, AOL, generic) ──────────────────────────────────────────────
# Per-account creds are entered by users at runtime; nothing to set here.
# For Yahoo/AOL users must generate an app password.

# ─── Upstash Redis (token + cache storage) ───────────────────────────────────
# Vercel Marketplace → Upstash (free tier). Skip locally — in-memory fallback used.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
